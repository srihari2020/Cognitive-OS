{
  "name": "cognitive-os-desktop",
  "private": true,
  "version": "1.0.0",
  "description": "Cognitive OS premium floating desktop assistant",
  "author": "Cognitive OS Team <team@cognitiveos.local>",
  "license": "UNLICENSED",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite --host 127.0.0.1 --port 5173\" \"wait-on tcp:5173 && cross-env ELECTRON_RENDERER_URL=http://127.0.0.1:5173 electron ./electron/main.cjs\"",
    "electron:start": "electron ./electron/main.cjs",
    "build:backend": "python -m PyInstaller --noconfirm --onefile --name cognitive-backend --distpath backend-dist --workpath .pyinstaller/build --specpath .pyinstaller/spec --collect-all fastapi --collect-all starlette --collect-all pydantic --collect-all uvicorn ../server.py",
    "package:win": "npm run build && npm run build:backend && electron-builder --config electron-builder.yml --win nsis",
    "package:dir": "npm run build && npm run build:backend && electron-builder --config electron-builder.yml --dir"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@tailwindcss/vite": "^4.2.2",
    "animejs": "^4.3.6",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.6.0",
    "matter-js": "^0.20.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.3",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.1",
    "wait-on": "^9.0.1"
  },
  "repository": {
    "type": "git",
    "url": "https://example.com/cognitive-os.git"
  }
}
